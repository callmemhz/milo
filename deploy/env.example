# Public DNS root for user apps. Wildcard (*.app.example.com) must point to this host.
ROOT_DOMAIN=app.example.com

# Public hostname for the Milo Apps Kit REST API. Single A record to this host.
API_DOMAIN=milo-apps-kit.example.com

# Docker network name. Override only if it conflicts with an existing network.
MILO_APPS_KIT_NETWORK=milo-apps-kit-net

# Milo Apps Kit server image tag.
MILO_APPS_KIT_VERSION=latest

# GitHub Container Registry credentials (read:packages PAT for a bot account
# that's a member of your org). Used to pull user app images.
GHCR_USER=callmemhz-milo-apps-kit-bot
GHCR_TOKEN=ghp_replace_me

# DNS provider API token for the wildcard certificate (DNS-01 challenge).
# Cloudflare token must have Zone:DNS:Edit on the root zone.
DNS_API_TOKEN=replace_me

