{{define "title"}}{{call .T "nav.overview"}} · milo console{{end}}
{{define "content"}}
<h1>{{call .T "dash.my_instances"}}</h1>
{{if not .Apps}}<p class="muted">{{call .T "dash.no_apps"}}</p>{{else}}
<section class="card pad0">
  <table class="tbl">
    <thead><tr><th>{{call .T "col.name"}}</th><th>{{call .T "col.state"}}</th><th>{{call .T "col.uptime"}}</th><th>{{call .T "col.mem"}}</th></tr></thead>
    <tbody>
    {{range .Apps}}
      <tr>
        <td><a href="/console/apps/{{.Name}}" class="mono">{{.Name}}</a></td>
        <td><span class="badge state-{{.State}}">{{.State}}</span></td>
        <td>{{if .Uptime}}{{.Uptime}}{{else}}—{{end}}</td>
        <td>{{if .Mem}}{{.Mem}}{{else}}—{{end}}</td>
      </tr>
    {{end}}
    </tbody>
  </table>
</section>
{{end}}

<h1>{{call .T "dash.my_dbs"}}</h1>
{{if not .Addons}}<p class="muted">{{call .T "dash.no_addons"}}</p>{{else}}
<section class="card pad0">
  <table class="tbl">
    <thead><tr><th>{{call .T "col.name"}}</th><th>{{call .T "col.engine"}}</th><th>{{call .T "col.state"}}</th><th>{{call .T "col.uptime"}}</th><th>{{call .T "col.mem"}}</th><th>{{call .T "col.external"}}</th></tr></thead>
    <tbody>
    {{$root := .}}
    {{range .Addons}}
      <tr>
        <td><a href="/console/addons/{{.Name}}" class="mono">{{.Name}}</a></td>
        <td>{{.Engine}}</td>
        <td><span class="badge state-{{.Status}}">{{.Status}}</span></td>
        <td>{{if .Uptime}}{{.Uptime}}{{else}}—{{end}}</td>
        <td>{{if .Mem}}{{.Mem}}{{else}}—{{end}}</td>
        <td>{{if .Exposed}}<span class="yes ico">{{call $root.T "common.on"}}</span>{{else}}<span class="no ico">{{call $root.T "common.off"}}</span>{{end}}</td>
      </tr>
    {{end}}
    </tbody>
  </table>
</section>
{{end}}
{{end}}
