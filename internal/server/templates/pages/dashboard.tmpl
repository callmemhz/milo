{{define "title"}}概览 · milo console{{end}}
{{define "content"}}
<h1>我的实例</h1>
{{if not .Apps}}<p class="muted">还没有 app。</p>{{else}}
<section class="card pad0">
  <table class="tbl">
    <thead><tr><th>名称</th><th>状态</th><th>运行</th><th>内存</th></tr></thead>
    <tbody>
    {{range .Apps}}
      <tr>
        <td><a href="/console/apps/{{.Name}}" class="mono">{{.Name}}</a></td>
        <td><span class="badge state-{{.State}}">{{.State}}</span></td>
        <td>{{if .Uptime}}{{.Uptime}}{{else}}—{{end}}</td>
        <td>{{if .Mem}}{{.Mem}}{{else}}—{{end}}</td>
      </tr>
    {{end}}
    </tbody>
  </table>
</section>
{{end}}

<h1>我的数据库 / Add-ons</h1>
{{if not .Addons}}<p class="muted">还没有 add-on。</p>{{else}}
<section class="card pad0">
  <table class="tbl">
    <thead><tr><th>名称</th><th>引擎</th><th>状态</th><th>运行</th><th>内存</th><th>外部访问</th></tr></thead>
    <tbody>
    {{range .Addons}}
      <tr>
        <td><a href="/console/addons/{{.Name}}" class="mono">{{.Name}}</a></td>
        <td>{{.Engine}}</td>
        <td><span class="badge state-{{.Status}}">{{.Status}}</span></td>
        <td>{{if .Uptime}}{{.Uptime}}{{else}}—{{end}}</td>
        <td>{{if .Mem}}{{.Mem}}{{else}}—{{end}}</td>
        <td>{{if .Exposed}}<span class="yes ico">✓ 开启</span>{{else}}<span class="no ico">✕ 关闭</span>{{end}}</td>
      </tr>
    {{end}}
    </tbody>
  </table>
</section>
{{end}}
{{end}}
