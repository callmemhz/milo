{{define "title"}}概览 · milo console{{end}}
{{define "content"}}
<h1>我的实例</h1>
{{if not .Apps}}<p class="muted">还没有 app。</p>{{end}}
<div class="grid">
  {{range .Apps}}
  <a class="card app" href="/console/apps/{{.Name}}">
    <div class="card-head">
      <span class="name">{{.Name}}</span>
      <span class="badge state-{{.State}}">{{.State}}</span>
    </div>
    <dl class="kv">
      <div><dt>运行</dt><dd>{{if .Uptime}}{{.Uptime}}{{else}}—{{end}}</dd></div>
      <div><dt>内存</dt><dd>{{if .Mem}}{{.Mem}}{{else}}—{{end}}</dd></div>
      {{if .Owners}}<div><dt>归属</dt><dd>{{.Owners}}</dd></div>{{end}}
    </dl>
  </a>
  {{end}}
</div>

<h1>我的数据库 / Add-ons</h1>
{{if not .Addons}}<p class="muted">还没有 add-on。</p>{{end}}
<div class="grid">
  {{range .Addons}}
  <div class="card addon">
    <div class="card-head">
      <span class="name">{{.Name}}</span>
      <span class="badge state-{{.Status}}">{{.Status}}</span>
    </div>
    <dl class="kv">
      <div><dt>引擎</dt><dd>{{.Engine}}</dd></div>
      <div><dt>运行</dt><dd>{{if .Uptime}}{{.Uptime}}{{else}}—{{end}}</dd></div>
      <div><dt>内存</dt><dd>{{if .Mem}}{{.Mem}}{{else}}—{{end}}</dd></div>
      <div><dt>外部访问</dt><dd>{{if .Exposed}}已开启{{else}}关闭{{end}}</dd></div>
      {{if .Owners}}<div><dt>归属</dt><dd>{{.Owners}}</dd></div>{{end}}
    </dl>
  </div>
  {{end}}
</div>
{{end}}
