{{define "title"}}{{.Name}} · milo console{{end}}
{{define "content"}}
{{$root := .}}
<p class="crumb"><a href="/console">{{call .T "common.back_overview"}}</a></p>
<div class="app-head">
  <h1>{{.Name}}</h1>
  <span class="badge state-{{.State}}">{{.State}}</span>
</div>
{{if .Error}}<p class="error left">{{.Error}}</p>{{end}}

<section class="card">
  <h2>{{call .T "sec.overview"}}</h2>
  <dl class="specs">
    <div class="cell"><dt>{{call .T "f.engine"}}</dt><dd>{{.Engine}} {{.Version}}</dd></div>
    <div class="cell"><dt>{{call .T "f.image"}}</dt><dd class="mono">{{if .Image}}{{.Image}}{{else}}—{{end}}</dd></div>
    <div class="cell"><dt>{{call .T "f.spec"}}</dt><dd>{{.Spec}}</dd></div>
    <div class="cell"><dt>{{call .T "f.uptime"}}</dt><dd>{{if .Uptime}}{{.Uptime}}{{else}}—{{end}}</dd></div>
    <div class="cell"><dt>{{call .T "f.mem"}}</dt><dd>{{if .Mem}}{{.Mem}}{{else}}—{{end}}</dd></div>
    <div class="cell"><dt>{{call .T "f.volume_usage"}}</dt><dd>{{.Volume}}</dd></div>
    <div class="cell"><dt>{{call .T "f.exposed"}}</dt><dd>{{if .Exposed}}<span class="tag use">{{call .T "common.enabled"}}</span>{{else}}<span class="tag free">{{call .T "common.disabled"}}</span>{{end}}</dd></div>
    {{if .ExternalHost}}<div class="cell"><dt>{{call .T "f.external_addr"}}</dt><dd class="mono">{{.ExternalHost}}</dd></div>{{end}}
  </dl>

  <div class="actions" style="margin-top:14px;display:flex;gap:10px;align-items:center">
    <form method="post" action="/console/addons/{{.Name}}/expose" class="inline">
      <input type="hidden" name="_csrf" value="{{.CSRF}}">
      {{if .Exposed}}
      <input type="hidden" name="exposed" value="false">
      <button type="submit" class="btn">{{call .T "addon.expose_off"}}</button>
      {{else}}
      <input type="hidden" name="exposed" value="true">
      <button type="submit" class="btn on">{{call .T "addon.expose_on"}}</button>
      {{end}}
    </form>
    <span class="muted" style="font-size:12px">{{call .T "addon.expose_note"}}</span>
  </div>

  {{if .ExternalURL}}
  <details class="reveal">
    <summary>{{call .T "addon.conn_string"}}</summary>
    <code class="conn">{{.ExternalURL}}</code>
  </details>
  {{end}}
  <div class="live" hx-ext="sse" sse-connect="/console/addons/{{.Name}}/stats/stream">
    <div class="metrics" sse-swap="stats" hx-swap="innerHTML"><span class="muted">—</span></div>
  </div>
</section>

<section class="card">
  <h2>{{call .T "sec.linked_apps"}}</h2>
  {{if .Links}}
  <table class="tbl">
    <thead><tr><th>{{call .T "col.app"}}</th><th>{{call .T "col.alias"}}</th></tr></thead>
    <tbody>
    {{range .Links}}<tr><td class="mono">{{.App}}</td><td class="mono">{{.Alias}}</td></tr>{{end}}
    </tbody>
  </table>
  {{else}}<p class="muted">{{call .T "addon.no_links"}}</p>{{end}}
</section>

<section class="card">
  <h2>{{call .T "sec.live_logs"}}</h2>
  <div hx-ext="sse" sse-connect="/console/addons/{{.Name}}/logs/stream">
    <pre class="logs" sse-swap="message" hx-swap="beforeend"></pre>
  </div>
</section>
{{end}}
