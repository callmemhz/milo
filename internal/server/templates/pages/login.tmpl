{{define "title"}}{{call .T "login.title"}} · milo console{{end}}
{{define "content"}}
<div class="login-wrap">
  <form class="card login" method="post" action="/console/login">
    <h1>milo console</h1>
    {{if .Error}}<p class="error">{{.Error}}</p>{{end}}
    <input type="hidden" name="_csrf" value="{{.CSRF}}">
    <label>{{call .T "login.username"}}<input name="username" autocomplete="username" autofocus required></label>
    <label>{{call .T "login.password"}}<input name="password" type="password" autocomplete="current-password" required></label>
    <button type="submit">{{call .T "login.signin"}}</button>
  </form>
</div>
{{end}}
